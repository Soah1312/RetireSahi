{
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/learn",
      "destination": "/learn/index.html"
    },
    {
      "source": "/methodology",
      "destination": "/methodology/index.html"
    },
    {
      "source": "/((?!api/|robots\\.txt$|sitemap\\.xml$).*)",
      "destination": "/index.html"
    }
  ]
}
